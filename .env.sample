# Do NOT store these values inside the project.
# Place them per applet outside the repo:
#
#   ~/.config/kilanka/<package.json-name>.env
#
# Example: ~/.config/kilanka/applet-starter-template.env
# (chmod 600). Alternatively, override the path with KILANKA_APPLET_ENV_FILE
# or export the variables directly as shell env.

KILANKA_APPLET_TOKEN=
KILANKA_APPLET_URL=http://localhost:4000
