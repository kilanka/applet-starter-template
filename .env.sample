# Diese Werte NICHT im Projekt ablegen.
# Lege sie pro Applet außerhalb des Repos ab:
#
#   ~/.config/kilanka/<package.json-name>.env
#
# Beispiel: ~/.config/kilanka/applet-starter-template.env
# (chmod 600). Alternativ den Pfad mit KILANKA_ENV_FILE übersteuern
# oder die Variablen direkt als Shell-Env exportieren.

KILANKA_APPLET_TOKEN=
KILANKA_APPLET_URL=http://localhost:4000
